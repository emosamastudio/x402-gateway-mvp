# Gateway ports
CORE_PORT=8402
ADMIN_PORT=8403

# Admin API key (leave empty to disable auth in dev)
ADMIN_API_KEY=change-me-in-production

# Database
DB_PATH=./gateway.db

# Facilitator wallet (private key for broadcasting settlements)
FACILITATOR_PRIVATE_KEY=0x...

# Chain RPCs
BASE_SEPOLIA_RPC=https://sepolia.base.org
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# USDC contract addresses (testnet)
BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
POLYGON_AMOY_USDC=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582

# ERC-8004 registry addresses (set if deployed on testnet, leave empty to use mock)
BASE_SEPOLIA_ERC8004_IDENTITY=
POLYGON_AMOY_ERC8004_IDENTITY=

# Set to "true" to bypass ERC-8004 check (dev only)
ERC8004_MOCK=true
