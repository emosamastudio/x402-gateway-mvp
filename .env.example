# Gateway ports
CORE_PORT=8402
ADMIN_PORT=8403

# Admin API key (leave empty to disable auth in dev)
ADMIN_API_KEY=change-me-in-production

# Database
DB_PATH=/absolute/path/to/gateway.db

# Facilitator wallet (private key for broadcasting settlements)
FACILITATOR_PRIVATE_KEY=0x...

# Chain RPCs
OPTIMISM_SEPOLIA_RPC=https://opt-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
SEPOLIA_RPC=https://eth-sepolia.nodereal.io/v1/<YOUR_NODEREAL_KEY>

# DMHKD token contract addresses
OPTIMISM_SEPOLIA_DMHKD=0x35348A0439Cd0198F10fbd6ACEc66D2506656DF6
SEPOLIA_DMHKD=0x1aA90392c804343C7854DD700f50a48961B71c53

# DMHKD EIP-712 domain per network
# Both contracts use "DMHKD" as domain name (matching symbol())
# NOTE: TOKEN_DOMAIN_NAMES are currently unused — DS is read directly from DOMAIN_SEPARATOR() on-chain
# Override with env vars if needed
OPTIMISM_SEPOLIA_TOKEN_DOMAIN_NAME=DMHKD
OPTIMISM_SEPOLIA_TOKEN_DOMAIN_VERSION=2
SEPOLIA_TOKEN_DOMAIN_NAME=DMHKD
SEPOLIA_TOKEN_DOMAIN_VERSION=2

# ERC-8004 registry addresses (set if deployed on testnet, leave empty to use mock)
OPTIMISM_SEPOLIA_ERC8004_IDENTITY=
SEPOLIA_ERC8004_IDENTITY=

# Set to "true" to bypass ERC-8004 check (dev only)
ERC8004_MOCK=true
