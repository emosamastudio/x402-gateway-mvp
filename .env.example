# ── 必填 / Required ──────────────────────────────────────────────

# 负责广播链上结算交易的钱包私钥（带 0x 前缀）
# Private key for the facilitator wallet that broadcasts settlement transactions
FACILITATOR_PRIVATE_KEY=0xyour_private_key_here

# 管理 API 认证密钥（生产环境务必修改）
# API key for Admin API authentication (must change in production)
ADMIN_API_KEY=change-me-in-production

# ── 可选 / Optional ─────────────────────────────────────────────

# SQLite 数据库文件路径，默认 ./gateway.db
# SQLite database file path, defaults to ./gateway.db
# DB_PATH=./gateway.db

# Gateway Core 端口，默认 8402
# Gateway Core listening port, defaults to 8402
# CORE_PORT=8402

# Admin API 端口，默认 8403
# Admin API listening port, defaults to 8403
# ADMIN_PORT=8403

# ── 链 RPC（首次启动时写入数据库，后续可通过 Admin UI 修改）──────
# Chain RPC URLs (seeded into DB on first run, editable via Admin UI afterwards)

# Optimism Sepolia RPC，默认 https://sepolia.optimism.io
# OPTIMISM_SEPOLIA_RPC=https://sepolia.optimism.io

# Ethereum Sepolia RPC，默认 https://rpc.sepolia.org
# SEPOLIA_RPC=https://rpc.sepolia.org

# ── 合约地址覆盖（不需要修改，除非使用自定义部署）───────────────
# Contract address overrides (no need to change unless using custom deployments)

# DMHKD 合约地址 — Optimism Sepolia
# OPTIMISM_SEPOLIA_DMHKD=0x35348A0439Cd0198F10fbd6ACEc66D2506656DF6

# DMHKD 合约地址 — Ethereum Sepolia
# SEPOLIA_DMHKD=0x1aA90392c804343C7854DD700f50a48961B71c53

# ERC-8004 Identity 合约地址（可选）
# OPTIMISM_SEPOLIA_ERC8004_IDENTITY=
# SEPOLIA_ERC8004_IDENTITY=

# ── Provider Portal ──────────────────────────────────────────────

# Provider Portal JWT 签名密钥（生产环境务必设置）
# JWT secret for signing provider tokens (must set in production)
# PROVIDER_JWT_SECRET=your_random_secret_here
